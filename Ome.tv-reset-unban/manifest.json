{
  "manifest_version": 3,
  "name": "Ome.tv Cleaner",
  "version": "2.6.0",
  "description": "Ome.tv Cleaner",
  "permissions": [
    "cookies",
    "browsingData",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://ome.tv/*",
    "*://www.ome.tv/*"
  ],
  "action": {
    "default_title": "Ome.tv Cleaner",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://ome.tv/*",
        "*://www.ome.tv/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
